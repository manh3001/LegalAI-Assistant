    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.19.2",
    "google-auth-library": "^10.6.2",
    "JSONStream": "^1.3.5",
    "jsonwebtoken": "^9.0.3",
    "mammoth": "^1.11.0",
    "msnodesqlv8": "^5.1.5",
    "mssql": "^12.2.1",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^4.2.1",
    "node-fetch": "^2.7.0",
    "nodemailer": "^8.0.4",
