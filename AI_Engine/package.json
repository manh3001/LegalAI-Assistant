{
  "name": "legai-engine",
  "version": "1.0.0",
  "description": "Microservice AI for LegAI Project",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "db:export": "py -m mssqlscripter -S MSI\\SQLEXPRESS -d LegalBotDB --schema-and-data -f ./data_export/full_db_sync.sql",
